# SSHFM Backend Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.

# Port the server listens on
SERVER_PORT=6969

# Node environment: development | production
NODE_ENV=development

# Optional: pre-fill SSH connection defaults (not required — users fill these in the UI)
# SSH_HOST=your-server.example.com
# SSH_PORT=22
# SSH_USERNAME=your-username
